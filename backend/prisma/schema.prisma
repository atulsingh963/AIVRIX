generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  CLIENT
  USER
}

enum ProjectStatus {
  PLANNING
  DEVELOPMENT
  TESTING
  DEPLOYED
  COMPLETED
  ON_HOLD
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

// ==========================================
// User & Client Management
// ==========================================

model User {
  id            String    @id @default(uuid())
  clerkId       String    @unique // For Clerk Auth integration
  email         String    @unique
  firstName     String?
  lastName      String?
  role          Role      @default(USER)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clientProfile Client?
  employeeProfile Employee?
  
  projectsManaged Project[] @relation("ProjectManager")
  tasksAssigned   Task[]    @relation("TaskAssignee")
  messages        Message[]
  ticketsAssigned Ticket[]  @relation("TicketAssignee")
}

model Client {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  industry      String?
  website       String?
  billingAddress String?
  
  projects      Project[]
  invoices      Invoice[]
  bookings      Booking[]
  tickets       Ticket[]
  contracts     Contract[]
  deals         Deal[]
}

// ==========================================
// HRMS (Employees, Departments, Leaves, Attendance)
// ==========================================

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  employees   Employee[]
  jobs        Job[]      @relation("DepartmentJobs")
}

model Employee {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  position      String
  salary        Float?
  joiningDate   DateTime    @default(now())
  
  attendances   Attendance[]
  leaves        Leave[]
}

model Attendance {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  checkIn     DateTime?
  checkOut    DateTime?
  status      String   @default("PRESENT") // PRESENT, ABSENT, HALF_DAY
}

model Leave {
  id          String      @id @default(uuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String      // SICK, CASUAL, ANNUAL
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      LeaveStatus @default(PENDING)
  
  createdAt   DateTime    @default(now())
}

// ==========================================
// CRM & Sales (Leads, Deals)
// ==========================================

model Lead {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  company     String?
  source      String?  // WEBSITE, REFERRAL, SOCIAL
  score       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Deal {
  id          String    @id @default(uuid())
  title       String
  value       Float
  stage       DealStage @default(LEAD)
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id])
  expectedCloseDate DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==========================================
// Project Management (Projects, Milestones, Tasks)
// ==========================================

model Project {
  id          String        @id @default(uuid())
  title       String
  description String?
  status      ProjectStatus @default(PLANNING)
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  managerId   String?       
  manager     User?         @relation("ProjectManager", fields: [managerId], references: [id])
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  
  milestones  Milestone[]
  tasks       Task[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Milestone {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  dueDate     DateTime?
  isCompleted Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}

model Task {
  id          String     @id @default(uuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueDate     DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ==========================================
// Support System (Tickets)
// ==========================================

model Ticket {
  id          String         @id @default(uuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ==========================================
// Document Management (Contracts, etc)
// ==========================================

model Contract {
  id          String   @id @default(uuid())
  title       String
  fileUrl     String
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  signed      Boolean  @default(false)
  signedAt    DateTime?
  
  createdAt   DateTime @default(now())
}

// ==========================================
// Communication (Messages, Bookings)
// ==========================================

model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

model Booking {
  id          String   @id @default(uuid())
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  guestName   String?
  guestEmail  String?
  meetingDate DateTime
  topic       String
  notes       String?
  
  createdAt   DateTime @default(now())
}

// ==========================================
// Billing & Invoices
// ==========================================

model Invoice {
  id          String        @id @default(uuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String        @default("USD")
  status      PaymentStatus @default(PENDING)
  dueDate     DateTime
  stripeId    String?       @unique
  pdfUrl      String?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ==========================================
// CMS: Blog, Careers, Testimonials
// ==========================================

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   
  excerpt     String?
  coverImage  String?
  published   Boolean  @default(false)
  authorId    String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id           String      @id @default(uuid())
  title        String
  departmentId String?
  department   Department? @relation("DepartmentJobs", fields: [departmentId], references: [id])
  location     String
  type         String   
  description  String
  isActive     Boolean     @default(true)
  
  createdAt    DateTime    @default(now())
}

model Testimonial {
  id          String   @id @default(uuid())
  clientName  String
  company     String
  content     String
  rating      Int      @default(5)
  avatarUrl   String?
  
  createdAt   DateTime @default(now())
}
